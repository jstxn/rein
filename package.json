{
  "name": "@jstxn/rein",
  "version": "0.2.1",
  "description": "REIN harness installer for Codex and Claude Code",
  "type": "module",
  "bin": {
    "rein": "bin/rein.js"
  },
  "oclif": {
    "bin": "rein",
    "commands": "./lib/commands",
    "topicSeparator": " "
  },
  "files": [
    "bin",
    "lib",
    "REIN.md",
    "AGENTS.md",
    ".codex/skills",
    ".claude/commands",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jstxn/rein.git"
  },
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "@oclif/core": "^4.10.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12"
  }
}
