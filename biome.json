{
  "$schema": "https://biomejs.dev/schemas/2.4.12/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "bin/**/*.js",
      "lib/**/*.js",
      "test/**/*.js",
      "test-support/**/*.js",
      "package.json"
    ],
    "maxSize": 1048576
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineEnding": "lf",
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedImports": "error"
      },
      "complexity": {
        "noExcessiveLinesPerFunction": {
          "level": "warn",
          "options": {
            "maxLines": 300,
            "skipBlankLines": true,
            "skipIifes": true
          }
        }
      },
      "nursery": {
        "noExcessiveLinesPerFile": {
          "level": "warn",
          "options": {
            "maxLines": 600,
            "skipBlankLines": true
          }
        }
      },
      "suspicious": {
        "noConsole": {
          "level": "warn",
          "options": {
            "allow": ["error", "warn"]
          }
        }
      }
    }
  },
  "javascript": {
    "globals": ["console", "process"],
    "jsxRuntime": "transparent",
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    },
    "parser": {
      "jsxEverywhere": false
    }
  },
  "overrides": [
    {
      "includes": ["test/**/*.js", "test-support/**/*.js"],
      "linter": {
        "rules": {
          "nursery": {
            "noExcessiveLinesPerFile": {
              "level": "warn",
              "options": {
                "maxLines": 1000,
                "skipBlankLines": true
              }
            }
          },
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    },
    {
      "includes": ["lib/core/installer*.js"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ]
}
